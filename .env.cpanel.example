# =============================================================================
# Shared-hosting (cPanel) .env — no Docker, no SeaweedFS, no queue/scheduler
# daemons, no Mailpit. Copy to `.env`, fill in the placeholders, then run
# `php artisan key:generate`. Full runbook: docs/infrastructure/deployment.md.
# =============================================================================

APP_NAME="RL Studio"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
# Keep production logs quiet; bump to debug only while troubleshooting.
LOG_LEVEL=warning

# --- Database: use the cPanel-created DB + user (usually cpaneluser_dbname) ---
DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cpaneluser_keenadmin
DB_USERNAME=cpaneluser_keen
DB_PASSWORD=change-me
# Shared MySQL/MariaDB usually has no TLS — keep mysqldump from demanding it.
DB_BACKUP_SKIP_SSL=true

# DB-backed session/cache/queue need zero extra services on shared hosting.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# HTTPS-only cookies in production.
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# --- Queue: database + a cron-driven worker (see the doc's cron section). ---
# Heavy exports/imports/backups run off-request. Fallback for the simplest
# possible setup: QUEUE_CONNECTION=sync (jobs run inline; big ones risk a PHP
# max_execution_time timeout).
QUEUE_CONNECTION=database
# MUST stay >= the longest job timeout (FinalizeExportJob = 600s).
DB_QUEUE_RETRY_AFTER=700

CACHE_STORE=database

# Telescope is a dev-only dashboard and isn't installed in a --no-dev build.
TELESCOPE_ENABLED=false
# Pulse (prod health dashboard at /pulse, developer-gated) is DB-backed — fine
# to leave on; flip to false if the host is resource-constrained.
PULSE_ENABLED=true

# --- Mail: real SMTP (cPanel mail account or an external provider). ---
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mail.your-domain.com
MAIL_PORT=587
MAIL_USERNAME=noreply@your-domain.com
MAIL_PASSWORD=change-me
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Storage: no SeaweedFS here — all feature disks live on the local disk
# under storage/app/private/* (outside the web root; downloads stay gated). ---
BACKUPS_DISK_DRIVER=local
EXPORTS_DISK_DRIVER=local
IMPORTS_DISK_DRIVER=local
UPLOADS_DISK_DRIVER=local

# Exports/imports sharding (config/keen.php). Exports at/below the threshold run
# inline; larger ones — and ALL imports — queue and shard.
EXPORT_SYNC_THRESHOLD=100
EXPORT_SHARD_SIZE=5000
EXPORT_PDF_SHARD_SIZE=1000
IMPORT_SHARD_SIZE=5000

# Backup retention (days) + staleness alert (hours). Note: backups need the
# mysqldump/mariadb-dump binary — run `which mysqldump` first (see the doc).
BACKUP_KEEP_DAYS=30
BACKUP_ALERT_AFTER_HOURS=24

# Keyset pagination page size for list endpoints (config/keen.php).
PAGINATION_SIZE=20

VITE_APP_NAME="${APP_NAME}"

# If the SPA / mobile API is served from extra hostnames, list them so Sanctum
# treats them as stateful (first-party). APP_URL's host is added automatically.
# SANCTUM_STATEFUL_DOMAINS=your-domain.com,www.your-domain.com
