includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    paths:
        - app
        - database
        - config
        - routes

    # Vendor-generated migration published verbatim by `pulse:install`; its
    # match() on the DB driver trips match.unhandled and isn't ours to fix.
    excludePaths:
        - database/migrations/*_create_pulse_tables.php

    level: 5

    # Larastan checks Eloquent magic, facades, etc. New findings are surfaced;
    # known/legacy issues are parked in phpstan-baseline.neon.
    # checkModelProperties is intentionally OFF: BaseModel/concerns operate on
    # generic Model with dynamic, table-qualified columns (e.g. created_by,
    # "{table}.record_status") that this opt-in check can't statically resolve.
    checkOctaneCompatibility: false
