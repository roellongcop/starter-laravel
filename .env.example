APP_NAME="RL Studio"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# In production prefer structured JSON to stdout (12-factor) so logs are
# machine-parseable and carry the request_id (see AssignRequestId middleware):
#   LOG_CHANNEL=stderr
#   LOG_STDERR_FORMATTER=Monolog\Formatter\JsonFormatter

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=keen_admin
DB_USERNAME=keen
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# Seconds before the queue assumes a reserved job died and re-runs it. MUST exceed
# the longest job $timeout (FinalizeExportJob = 600s) or long jobs fail with
# "attempted too many times" (see docs/features/backups-exports-imports.md).
DB_QUEUE_RETRY_AFTER=700

# Laravel Telescope (dev-only debug dashboard at /telescope). Registered only in
# APP_ENV=local; gated to the developer role outside local. Forced off in tests.
TELESCOPE_ENABLED=true

# Laravel Pulse (prod app-health dashboard at /pulse, developer-gated). Toggles
# recording; forced off in tests.
PULSE_ENABLED=true

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Transport switch (like *_DISK_DRIVER for storage): "smtp" sends to Mailpit in
# dev (inbox at http://localhost:${MAILPIT_PORT}); "log" writes to storage/logs.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# SeaweedFS (S3-compatible) — used by the s3 disk and per-feature disks below.
AWS_ACCESS_KEY_ID=seaweedfs
AWS_SECRET_ACCESS_KEY=seaweedfs
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=uploads
AWS_ENDPOINT=http://seaweedfs:8333
AWS_USE_PATH_STYLE_ENDPOINT=true

# Non-public feature disks (roots live outside public/). Each switchable
# between "local" and "s3" without touching code.
BACKUPS_DISK_DRIVER=s3
EXPORTS_DISK_DRIVER=s3
IMPORTS_DISK_DRIVER=s3
UPLOADS_DISK_DRIVER=s3
BACKUPS_BUCKET=backups
EXPORTS_BUCKET=exports
IMPORTS_BUCKET=imports
UPLOADS_BUCKET=uploads

# Exports/imports (config/keen.php). Exports at/below EXPORT_SYNC_THRESHOLD run
# inline (instant download); larger ones — and ALL imports — queue and shard into
# *_SHARD_SIZE-row batches. PDF gets a smaller shard size because DomPDF renders a
# whole shard in memory.
EXPORT_SYNC_THRESHOLD=100
EXPORT_SHARD_SIZE=5000
EXPORT_PDF_SHARD_SIZE=1000
IMPORT_SHARD_SIZE=5000

# Retention window (days) for the weekly backups:prune command (config/keen.php).
# Older Generated/Failed backups are deleted; the latest generated one is always kept.
BACKUP_KEEP_DAYS=30

# Staleness threshold (hours) for the daily backups:monitor alert (config/keen.php).
# Developers are notified in-app if no successful backup completed within this window.
BACKUP_ALERT_AFTER_HOURS=24

# Keyset pagination page size for list endpoints (config/keen.php).
PAGINATION_SIZE=20

# Docker host port mappings
APP_PORT=8080
ADMINER_PORT=8081
MAILPIT_PORT=8025
VITE_PORT=5173
DB_FORWARD_PORT=5432
S3_PORT=8333
S3_MASTER_PORT=9333

VITE_APP_NAME="${APP_NAME}"
